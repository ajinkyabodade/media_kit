# Auto-detect text files and normalize line endings
* text=auto

# Force LF for source files
*.jsx text eol=lf
*.js  text eol=lf
*.css text eol=lf
*.json text eol=lf
*.html text eol=lf
*.md  text eol=lf
*.svg text eol=lf

# Binary files - no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
